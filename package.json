{
  "name": "mentorapredict",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "infra:up": "docker compose -f docker-compose.yml up -d postgres redis mongo",
    "infra:down": "docker compose -f docker-compose.yml down postgres redis mongo",
    "services:up": "docker compose -f docker-compose.yml up -d",
    "services:down": "docker compose -f docker-compose.yml down",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "prettier": "^3.2.0"
  }
}
