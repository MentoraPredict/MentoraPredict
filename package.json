{
  "name": "mentorapredict",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "build":    "turbo run build",
    "dev":      "turbo run dev",
    "lint":     "turbo run lint",
    "test":     "turbo run test",
    "clean":    "turbo run clean",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down"
  },
  "devDependencies": {
    "turbo":      "^2.0.0",
    "typescript": "^5.4.0"
  }
}
