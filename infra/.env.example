# ============================================================
# MentoraPredict — Environment Variables Template
# Copy to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ─── DockerHub ───────────────────────────────────────────────
DOCKERHUB_USERNAME=mentorapredict
DEV_IMAGE_TAG=dev-latest

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
API_PREFIX=/api/v1
API_VERSION=1
CORRELATION_HEADER=x-correlation-id
REQUEST_HEADER=x-request-id

# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mp_user
POSTGRES_PASSWORD=mp_secret_change_in_prod
POSTGRES_DB=mentorapredict
# Full connection URL (alternative to individual vars)
DATABASE_URL=postgresql://mp_user:mp_secret_change_in_prod@localhost:5432/mentorapredict

# ─── MongoDB ─────────────────────────────────────────────────
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=mp_mongo_user
MONGO_PASSWORD=mp_mongo_secret_change_in_prod
MONGO_DB=mentorapredict_nosql
MONGO_URL=mongodb://mp_mongo_user:mp_mongo_secret_change_in_prod@localhost:27017/mentorapredict_nosql?authSource=admin

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=mp_redis_secret_change_in_prod
REDIS_TTL_DEFAULT=3600

# ─── JWT (RS256) ─────────────────────────────────────────────
# Generate with: bash infra/kong/generate-kong-keys.sh
# Keys can be provided as base64-encoded PEM values or file paths.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY_PATH=/secrets/private.pem
JWT_PUBLIC_KEY_PATH=/secrets/public.pem
JWT_ACCESS_EXPIRES_IN=900        # 15 minutes (seconds)
JWT_REFRESH_EXPIRES_IN=604800    # 7 days (seconds)
JWT_ISSUER=mentorapredict
JWT_AUDIENCE=mentorapredict-api

# ─── Internal Service API Keys ───────────────────────────────
# Used for service-to-service calls (prediction-service)
INTERNAL_API_KEY=mp_internal_key_change_in_prod

# ─── Ports ───────────────────────────
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
ACADEMIC_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3004
PREDICTION_SERVICE_PORT=3006
WEB_PORT=3007

# ─── Microservice URLs (internal) ───────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
USER_SERVICE_URL=http://user-service:3002 # RF-014: Keep profiles in sync with auth-service
ACADEMIC_SERVICE_URL=http://academic-service:3003
ANALYTICS_SERVICE_URL=http://analytics-service:3004
RISK_HIGH_THRESHOLD=40
RISK_CRITICAL_THRESHOLD=25
PREDICTION_SERVICE_URL=http://prediction-service:3006

# ─── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# ─── Kong API Gateway (docker-compose.dev.yml) ───────────────
KONGA_PORT=1337

# ─── Rate Limiting (RNF-006) ─────────────────────────────────
RATE_LIMIT_TTL=60          # seconds
RATE_LIMIT_MAX=100         # requests per TTL window
AUTH_RATE_LIMIT_MAX=10     # stricter for auth endpoints

# ─── CORS ────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:5173,http://localhost:8000
CORS_METHODS=GET,POST,PUT,DELETE,PATCH

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug            # debug | info | warn | error
LOG_FORMAT=pretty          # pretty | json

# ─── Optional UI tools (docker-compose --profile tools) ─────
REDIS_UI_USER=admin
REDIS_UI_PASSWORD=admin
MONGO_UI_USER=admin
MONGO_UI_PASSWORD=admin

# ─── Monitoring (Grafana + Prometheus) ─────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_ROOT_URL=http://localhost:3000
ALERTMANAGER_SMTP_FROM=alertmanager@mentorapredict.com
ALERTMANAGER_SMTP_HOST=localhost:25
ALERTMANAGER_SMTP_TLS=false
ALERTMANAGER_EMAIL_TO=admin@mentorapredict.com
