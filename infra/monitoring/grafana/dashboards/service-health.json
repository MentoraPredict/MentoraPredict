{
  "title": "Service Health",
  "uid": "service-health",
  "version": 1,
  "tags": ["mentorapredict", "services"],
  "timezone": "browser",
  "editable": true,
  "panels": [
    {
      "title": "Service Status",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "up",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "instance": "Instance",
              "job": "Job",
              "up": "Status"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Services Up",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Up"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "green", "value": 4 }
            ]
          }
        }
      }
    },
    {
      "title": "Services Down",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "expr": "count(up == 0) or vector(0)",
          "legendFormat": "Down"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 2 }
            ]
          }
        }
      }
    },
    {
      "title": "Uptime Percentage",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "expr": "avg(up) * 100",
          "legendFormat": "Uptime"
        }
      ],
      "options": {
        "reduceOptions": { "values": false, "calcs": ["mean"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 80 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    },
    {
      "title": "Scrape Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "scrape_duration_seconds",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Scrape Samples",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "scrape_samples_scraped",
          "legendFormat": "{{ job }}"
        }
      ]
    },
    {
      "title": "Container Status by Service",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "container_last_seen{name=~\"mp_.*\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "name": "Container Name",
              "image": "Image",
              "container_last_seen": "Last Seen"
            }
          }
        }
      ]
    }
  ],
  "schemaVersion": 36
}
